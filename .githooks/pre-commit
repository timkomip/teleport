#!/bin/sh
echo "Running pre-commit checks..."

echo "→ Checking formatting..."
bun run fmt:check || { echo "Format check failed. Run 'bun run fmt' to fix."; exit 1; }

echo "→ Linting..."
bun run lint || { echo "Lint failed."; exit 1; }

echo "→ Running tests..."
bun test || { echo "Tests failed."; exit 1; }

echo "All checks passed."
